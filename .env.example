# Backend
NODE_ENV=development
PORT=4000
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=stryk_user
DATABASE_PASSWORD=stryk_pass
DATABASE_NAME=stryker_jtts
# Optional DATABASE_URL (overrides the above)
# DATABASE_URL=postgresql://stryk_user:stryk_pass@postgres:5432/stryker_jtts

REDIS_URL=redis://redis:6379

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=stryker-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Optional: disable/adjust backend retention cleanup scheduler
# MEDIA_RETENTION_SCHEDULED=true
# MEDIA_RETENTION_INTERVAL_HOURS=24

JWT_SECRET=changeme-local-jwt-secret
ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=AdminPass123!

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:4173

# Frontend
VITE_API_URL=http://localhost:4000/api
VITE_S3_ENDPOINT=http://localhost:9000
VITE_S3_BUCKET=stryker-uploads
NODE_ENV=development
