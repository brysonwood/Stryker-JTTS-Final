{
  "name": "stryker-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "postinstall": "npx prisma@5 generate",
    "migrate": "npx prisma@5 migrate dev",
    "prisma:generate": "npx prisma@5 generate",
    "prisma:deploy": "npx prisma@5 migrate deploy",
    "seed": "node scripts/seed.js",
    "worker:pdf": "ts-node-dev --respawn --transpile-only src/workers/pdfWorker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "pdfkit": "^0.17.2",
    "redis": "^4.7.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^18.0.0",
    "@types/pdfkit": "^0.13.9",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
